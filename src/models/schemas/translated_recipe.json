{
  "description": "Recipe entity with fields optimized for similarity search.",
  "properties": {
    "dish_name": {
      "title": "Dish Name",
      "type": "string"
    },
    "description": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "default": null,
      "title": "Description"
    },
    "instructions": {
      "title": "Instructions",
      "type": "string"
    },
    "ingredients": {
      "items": { "type": "string" },
      "title": "Ingredients",
      "type": "array"
    },
    "ingredients_with_amounts": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name":   { "type": "string" },
              "amount": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
              "unit":   { "anyOf": [{ "type": "string" }, { "type": "null" }] }
            },
            "required": ["name"]
          }
        },
        { "type": "null" }
      ],
      "default": null,
      "title": "Ingredients with Amounts"
    },
    "tags": {
      "anyOf": [
        { "items": { "type": "string" }, "type": "array" },
        { "type": "null" }
      ],
      "default": null,
      "title": "Tags"
    },
    "category": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "default": null,
      "title": "Category"
    },
    "cook_time": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "default": null,
      "title": "Cook Time"
    },
    "prep_time": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "default": null,
      "title": "Prep Time"
    },
    "total_time": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "default": null,
      "title": "Total Time"
    }
  },
  "required": ["dish_name", "instructions"],
  "title": "Recipe",
  "type": "object"
}